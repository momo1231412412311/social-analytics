# ============================================================
#  Rival — Competitor Analytics Dashboard
#  Copy to .env.local and fill in your values
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Create a free project at https://supabase.com
# Run supabase/schema.sql in the SQL Editor, then copy these:
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── YouTube Data API v3 (official, free) ─────────────────────
# 1. https://console.cloud.google.com → Create project
# 2. APIs & Services → Enable "YouTube Data API v3"
# 3. APIs & Services → Credentials → Create API key
#    (restrict to YouTube Data API v3 for security)
YOUTUBE_API_KEY=AIza...

# ── RapidAPI (Instagram + TikTok public data) ────────────────
# 1. Create a free account at https://rapidapi.com
# 2. Subscribe to both of these APIs (free tier available):
#
#    Instagram: "Instgram" by omarmhaimdat
#    → https://rapidapi.com/omarmhaimdat/api/instagram230
#
#    TikTok: "Tiktok API" by Lundehund
#    → https://rapidapi.com/Lundehund/api/tiktok-api23
#
# 3. Both use the same API key (shown in any subscribed API → Header: x-rapidapi-key)
RAPIDAPI_KEY=your-rapidapi-key-here

# Optional: override the RapidAPI host if you use a different provider
# INSTAGRAM_RAPIDAPI_HOST=instagram230.p.rapidapi.com
# TIKTOK_RAPIDAPI_HOST=tiktok-api23.p.rapidapi.com

# ── App URL ───────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Netlify: https://your-site.netlify.app (also set in Netlify dashboard)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
