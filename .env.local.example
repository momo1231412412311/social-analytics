# ============================================================
#  Rival — Competitor Analytics Dashboard
#  Copy this file to .env.local and fill in your values
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Create a free project at https://supabase.com
# Settings → API → copy Project URL + service_role key
# Run supabase/schema.sql in the SQL Editor first
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── YouTube Data API v3 ───────────────────────────────────────
# 1. https://console.cloud.google.com → Create project
# 2. APIs & Services → Enable "YouTube Data API v3"
# 3. APIs & Services → Credentials → Create API key
YOUTUBE_API_KEY=AIza...

# ── TikTok — EnsembleData API ────────────────────────────────
# Free 7-day trial, no credit card: https://ensembledata.com
# Dashboard → copy your token
ENSEMBLEDATA_TOKEN=your-ensembledata-token-here

# ── Instagram — Piloterr API ──────────────────────────────────
# Optional — falls back to meta-tag scraping (profile-only) if not set
# Free tier: https://piloterr.com → Dashboard → API Key
PILOTERR_API_KEY=your-piloterr-key-here

# ── Twitter/X + competitor search — RapidAPI ─────────────────
# 1. Create free account at https://rapidapi.com
# 2. Subscribe to "Twitter135" (free tier available)
#    https://rapidapi.com/twitter135/api/twitter135
# 3. Copy your x-rapidapi-key from any subscribed API
RAPIDAPI_KEY=your-rapidapi-key-here
# Optional: override if using a different Twitter API provider
# TWITTER_RAPIDAPI_HOST=twitter135.p.rapidapi.com

# ── App URL ───────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Production: set to your Netlify URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000
