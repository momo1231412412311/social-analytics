# ============================================================
#  Rival — Competitor Analytics Dashboard
#  Copy to .env.local and fill in your values
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Create a free project at https://supabase.com
# Run supabase/schema.sql in the SQL Editor, then copy these:
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── YouTube Data API v3 (official, free) ─────────────────────
# 1. https://console.cloud.google.com → Create project
# 2. APIs & Services → Enable "YouTube Data API v3"
# 3. APIs & Services → Credentials → Create API key
#    (restrict to YouTube Data API v3 for security)
YOUTUBE_API_KEY=AIza...

# ── Instagram (no API key needed) ────────────────────────────
# Instagram data is scraped directly from public profile pages.
# No configuration required — it works out of the box.
# Note: Instagram rate-limits scrapers; the 6-hour cache reduces requests.

# ── TikTok — EnsembleData API (free tier, no card needed) ────
# 1. Sign up at https://ensembledata.com/ (7-day free trial)
# 2. Copy your token from the dashboard
ENSEMBLEDATA_TOKEN=your-ensembledata-token-here

# ── App URL ───────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Netlify: https://your-site.netlify.app (also set in Netlify dashboard)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
