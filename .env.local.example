# ============================================================
#  Social Analytics Dashboard — Environment Variables
#  Copy this file to .env.local and fill in your credentials
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# 1. Create a free project at https://supabase.com
# 2. Project Settings → API → copy these values
# 3. Run supabase/schema.sql in the Supabase SQL Editor
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App base URL ──────────────────────────────────────────────
# Local: http://localhost:3000
# Netlify: https://your-site.netlify.app  (also add to Netlify env vars)
# On Netlify this falls back to the automatic $URL env var if not set
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Instagram / Meta ─────────────────────────────────────────
# 1. Go to https://developers.facebook.com/
# 2. Create an App → Business type
# 3. Add "Instagram Graph API" + "Facebook Login" products
# 4. Facebook Login → Settings → add OAuth redirect URI:
#    http://localhost:3000/api/auth/instagram/callback
#    (and your Netlify URL for production)
# 5. Required permissions: instagram_basic, instagram_manage_insights,
#    pages_show_list, pages_read_engagement
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ── TikTok ───────────────────────────────────────────────────
# 1. Go to https://developers.tiktok.com/
# 2. Create an app → add "Login Kit" product
# 3. Add redirect URI: http://localhost:3000/api/auth/tiktok/callback
# 4. Required scopes: user.info.basic, video.list
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── YouTube / Google ─────────────────────────────────────────
# 1. https://console.cloud.google.com/ → Create project
# 2. Enable: YouTube Data API v3 + YouTube Analytics API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Authorized redirect URIs:
#    http://localhost:3000/api/auth/youtube/callback
#    (and your Netlify URL for production)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── Security ─────────────────────────────────────────────────
# Random 32-char secret for OAuth state cookie signing
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
